        "文化、体育和娱乐业": ["参保人员2024", "参保人员2023", "参保人员2022", "参保人员2021", "参保人员2020", "参保人员2019", "参保人员2018", "参保人员2017", "参保人员2016", "参保人员2015", "参保人员2014", "参保人员2013", "参保人员2012", "参保人员2011", "参保人员2010", "参保人员2009", "参保人员2008", "参保人员2007", "参保人员2006", "参保人员2005", "参保人员2004", "参保人员2003", "参保人员2002", "参保人员2001", "参保人员2000", "参保人员1999", "参保人员1998", "参保人员1997", "参保人员1996", "参保人员1995", "参保人员1994", "参保人员1993", "参保人员1992", "参保人员1991", "参保人员1990"],
        "高新企业": ["2024年参保人数", "2023年参保人数", "2022年参保人数", "2021年参保人数", "2020年参保人数", "2019年参保人数", "2018年参保人数", "2017年参保人数", "2016年参保人数", "2015年参保人数", "2014年参保人数", "2013年参保人数"]
