{
  "data_schema": {
    "description": "基于实际数据字段的知识图谱数据存储方案",
    "version": "1.0",
    "last_updated": "2024-12-19"
  },
  "entity_data_mapping": {
    "Policy1": {
      "description": "国家级政策",
      "source_file": "政策数据.xlsx",
      "fields": {
        "标题": "string",
        "发布时间": "date", 
        "发布单位": "string",
        "内容": "text",
        "政策级别": "enum",
        "政策解读": "text"
      },
      "data_examples": {
        "标题": "工业和信息化部办公厅关于印发《场景化、图谱化推进重点行业数字化转型的参考指引（2025版）》",
        "发布时间": "2025-01-15",
        "发布单位": "工业和信息化部",
        "政策级别": "国家",
        "政策解读": "无"
      }
    },
    "Policy2": {
      "description": "自治区级政策",
      "source_file": "政策数据.xlsx",
      "fields": {
        "标题": "string",
        "发布时间": "date", 
        "发布单位": "string",
        "内容": "text",
        "政策级别": "enum",
        "政策解读": "text"
      },
      "data_examples": {
        "标题": "广西壮族自治区工业和信息化厅关于印发...",
        "发布时间": "2025-01-15",
        "发布单位": "广西壮族自治区工业和信息化厅",
        "政策级别": "自治区",
        "政策解读": "无"
      }
    },
    "Policy3": {
      "description": "市级政策",
      "source_file": "政策数据.xlsx",
      "fields": {
        "标题": "string",
        "发布时间": "date", 
        "发布单位": "string",
        "内容": "text",
        "政策级别": "enum",
        "政策解读": "text"
      },
      "data_examples": {
        "标题": "柳州市人民政府关于...",
        "发布时间": "2025-01-15",
        "发布单位": "柳州市人民政府",
        "政策级别": "柳州",
        "政策解读": "无"
      }
    },
    "Industry": {
      "description": "行业实体，从企业数据的行业大类字段提取",
      "source": "企业数据文件的行业大类分类",
      "types": [
        "ManufacturingIndustry",
        "TechnologyServiceIndustry",
        "CulturalEntertainmentIndustry",
        "InfrastructureIndustry",
        "HighTechIndustry",
        "WaterEnvironmentIndustry"
      ],
      "fields": {
        "行业名称": "string",
        "行业代码": "string"
      },
      "mapping": {
        "制造业": "ManufacturingIndustry",
        "科学研究和技术服务业": "TechnologyServiceIndustry",
        "文化、体育和娱乐业": "CulturalEntertainmentIndustry",
        "水利、环境和公共设施管理业": "InfrastructureIndustry",
        "高新企业": "HighTechIndustry",
        "电力、热力、燃气及水生产和供应业": "WaterEnvironmentIndustry"
      }
    },
    "Enterprise": {
      "source_files": [
        "文化、体育和娱乐业.xlsx",
        "高新企业.xlsx"
      ],
      "common_fields": {
        "企业名称": "string",
        "经营状态": "enum",
        "法定代表人": "string",
        "注册资本": "number",
        "成立日期": "date",
        "所属省份": "string",
        "所属城市": "string",
        "所属区县": "string",
        "企业类型": "enum",
        "所属行业": "enum",
        "经营范围": "text",
        "行业大类": "string",
        "参保人员数据": "object"
      },
      "time_series_fields": {
        "文化、体育和娱乐业": {
          "参保人员": "1990-2024年",
          "从业人数": "1990-2024年", 
          "企业经营状态": "1990-2024年"
        },
        "高新企业": {
          "参保人数": "2013-2024年"
        }
      }
    }
  },
  "time_series_data_structure": {
    "description": "时间序列数据存储结构",
    "format": "entity_id + year + indicator_type + value",
    "examples": [
      {
        "entity_id": "enterprise_001",
        "entity_name": "广西汇恩娱乐股份有限公司",
        "year": 2024,
        "indicator_type": "参保人员",
        "value": 150,
        "data_source": "文化、体育和娱乐业.xlsx"
      },
      {
        "entity_id": "enterprise_002", 
        "entity_name": "东风柳州汽车有限公司",
        "year": 2024,
        "indicator_type": "参保人数",
        "value": 5000,
        "data_source": "高新企业.xlsx"
      }
    ]
  },
  "indicator_mapping": {
