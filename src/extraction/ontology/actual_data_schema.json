      "source_fields": {
        "文化、体育和娱乐业": ["从业人数2024", "从业人数2023", "从业人数2022", "从业人数2021", "从业人数2020", "从业人数2019", "从业人数2018", "从业人数2017", "从业人数2016", "从业人数2015", "从业人数2014", "从业人数2013", "从业人数2012", "从业人数2011", "从业人数2010", "从业人数2009", "从业人数2008", "从业人数2007", "从业人数2006", "从业人数2005", "从业人数2004", "从业人数2003", "从业人数2002", "从业人数2001", "从业人数2000", "从业人数1999", "从业人数1998", "从业人数1997", "从业人数1996", "从业人数1995", "从业人数1994", "从业人数1993", "从业人数1992", "从业人数1991", "从业人数1990"]
