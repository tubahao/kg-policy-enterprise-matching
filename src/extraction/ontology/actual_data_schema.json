    "企业经营状态": {
      "description": "企业经营状态",
      "data_type": "enum",
      "values": ["存续", "在业", "注销", "吊销", "停业"],
      "time_range": "1990-2024",
      "source_fields": {
        "文化、体育和娱乐业": ["企业经营状态2024", "企业经营状态2023", "企业经营状态2022", "企业经营状态2021", "企业经营状态2020", "企业经营状态2019", "企业经营状态2018", "企业经营状态2017", "企业经营状态2016", "企业经营状态2015", "企业经营状态2014", "企业经营状态2013", "企业经营状态2012", "企业经营状态2011", "企业经营状态2010", "企业经营状态2009", "企业经营状态2008", "企业经营状态2007", "企业经营状态2006", "企业经营状态2005", "企业经营状态2004", "企业经营状态2003", "企业经营状态2002", "企业经营状态2001", "企业经营状态2000", "企业经营状态1999", "企业经营状态1998", "企业经营状态1997", "企业经营状态1996", "企业经营状态1995", "企业经营状态1994", "企业经营状态1993", "企业经营状态1992", "企业经营状态1991", "企业经营状态1990"]
      }
    }
  },
  "data_extraction_rules": {
    "description": "数据提取规则",
    "enterprise_extraction": {
      "basic_info": {
        "企业名称": "直接提取",
        "经营状态": "直接提取",
        "法定代表人": "直接提取",
        "注册资本": "数值转换（去除'万(元)'等后缀）",
        "成立日期": "日期格式转换",
        "所属省份": "直接提取",
        "所属城市": "直接提取", 
        "所属区县": "直接提取",
        "企业类型": "直接提取",
        "所属行业": "直接提取",
        "经营范围": "直接提取"
      },
      "time_series_extraction": {
        "参保人员": {
          "rule": "提取所有'参保人员YYYY'字段的数值",
          "data_cleaning": "去除'人'等后缀，转换为整数",
          "missing_value": "NaN表示该年份无数据"
        },
        "从业人数": {
          "rule": "提取所有'从业人数YYYY'字段的数值", 
          "data_cleaning": "去除'人'等后缀，转换为整数",
          "missing_value": "NaN表示该年份无数据"
        },
        "企业经营状态": {
          "rule": "提取所有'企业经营状态YYYY'字段的值",
          "data_cleaning": "标准化状态值",
          "missing_value": "NaN表示该年份无数据"
        }
      }
    },
    "policy_extraction": {
      "basic_info": {
        "标题": "直接提取",
        "发布时间": "日期格式转换",
        "发布单位": "直接提取",
        "内容": "直接提取",
        "政策级别": "从地区字段提取并标准化"
      }
    }
  },
  "knowledge_graph_storage": {
    "description": "知识图谱存储结构",
    "entities": {
      "Policy1": {
        "id": "policy1_{index}",
        "type": "Policy1",
        "attributes": ["标题", "发布时间", "发布单位", "内容", "政策级别", "政策解读"],
        "relationships": ["transmitsTo", "targetsIndustry"]
      },
      "Policy2": {
        "id": "policy2_{index}",
        "type": "Policy2",
        "attributes": ["标题", "发布时间", "发布单位", "内容", "政策级别", "政策解读"],
        "relationships": ["transmitsTo", "executes", "targetsIndustry", "supports"]
      },
      "Policy3": {
        "id": "policy3_{index}",
        "type": "Policy3",
        "attributes": ["标题", "发布时间", "发布单位", "内容", "政策级别", "政策解读"],
        "relationships": ["executes", "targetsIndustry", "supports"]
      },
      "ManufacturingIndustry": {
        "id": "industry_manufacturing",
        "type": "ManufacturingIndustry",
        "attributes": ["行业名称", "行业代码"],
        "relationships": ["targetsIndustry", "belongsTo"]
      },
      "TechnologyServiceIndustry": {
        "id": "industry_tech_service",
        "type": "TechnologyServiceIndustry",
        "attributes": ["行业名称", "行业代码"],
        "relationships": ["targetsIndustry", "belongsTo"]
      },
      "CulturalEntertainmentIndustry": {
        "id": "industry_cultural",
        "type": "CulturalEntertainmentIndustry",
        "attributes": ["行业名称", "行业代码"],
        "relationships": ["targetsIndustry", "belongsTo"]
      },
      "InfrastructureIndustry": {
        "id": "industry_infrastructure",
        "type": "InfrastructureIndustry",
        "attributes": ["行业名称", "行业代码"],
        "relationships": ["targetsIndustry", "belongsTo"]
      },
      "HighTechIndustry": {
        "id": "industry_high_tech",
        "type": "HighTechIndustry",
        "attributes": ["行业名称", "行业代码"],
        "relationships": ["targetsIndustry", "belongsTo"]
      },
      "WaterEnvironmentIndustry": {
        "id": "industry_water_env",
        "type": "WaterEnvironmentIndustry",
        "attributes": ["行业名称", "行业代码"],
        "relationships": ["targetsIndustry", "belongsTo"]
      },
      "Enterprise": {
        "id": "enterprise_{index}",
        "type": "Enterprise", 
        "attributes": ["企业名称", "经营状态", "法定代表人", "注册资本", "成立日期", "所属省份", "所属城市", "所属区县", "企业类型", "所属行业", "经营范围", "行业大类", "参保人员数据"],
        "relationships": ["implements", "belongsTo"],
        "time_series": ["参保人员数据"]
      }
    },
    "relationships": {
      "transmitsTo": {
        "description": "政策传达关系（逐级）",
        "subject": "Policy1|Policy2",
        "object": "Policy2|Policy3",
        "constraints": "Policy1->Policy2, Policy2->Policy3（禁止Policy1->Policy3）",
        "attributes": ["传达时间", "传达方式", "传达效果"]
      },
      "executes": {
        "description": "政策执行关系（逐级）",
        "subject": "Policy2|Policy3", 
        "object": "Policy1|Policy2",
        "constraints": "Policy2->Policy1, Policy3->Policy2（禁止Policy3->Policy1）",
        "attributes": ["执行时间", "执行方式", "执行效果"]
      },
      "targetsIndustry": {
        "description": "政策影响行业关系",
        "subject": "Policy1|Policy2|Policy3",
        "object": "ManufacturingIndustry|TechnologyServiceIndustry|CulturalEntertainmentIndustry|InfrastructureIndustry|HighTechIndustry|WaterEnvironmentIndustry",
        "attributes": ["影响时间", "影响程度", "支持方式"]
      },
      "supports": {
        "description": "政策支持企业关系（Policy2/Policy3可以，Policy1不能）",
        "subject": "Policy2|Policy3",
        "object": "Enterprise",
        "constraints": "Policy2/Policy3可以支持企业，Policy1不能直接支持企业",
        "attributes": ["支持力度", "支持方式", "支持效果"]
      },
      "implements": {
        "description": "企业实施政策关系（企业不能实施Policy1）",
        "subject": "Enterprise",
        "object": "Policy2|Policy3",
        "constraints": "企业只能实施Policy2或Policy3，不能实施Policy1",
        "attributes": ["实施时间", "实施程度", "实施效果"]
      },
      "belongsTo": {
        "description": "企业属于行业关系（分类关系）",
        "subject": "Enterprise",
        "object": "ManufacturingIndustry|TechnologyServiceIndustry|CulturalEntertainmentIndustry|InfrastructureIndustry|HighTechIndustry|WaterEnvironmentIndustry",
        "attributes": ["关联时间"]
      }
    }
  }
}
