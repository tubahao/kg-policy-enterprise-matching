      "内容": "text",
      "政策级别": "enum",
      "政策解读": "text"
    },
    "attribute_constraints": {
      "标题": {"required": true, "max_length": 200},
      "发布时间": {"required": true, "format": "YYYY-MM-DD"},
      "发布单位": {"required": true, "max_length": 100},
      "内容": {"required": true, "min_length": 10},
      "政策级别": {"required": true, "values": ["国家"]},
      "政策解读": {"required": false, "max_length": 10000, "default": "无"}
    },
    "examples": ["国务院政策", "工信部政策", "科技部政策"],
    "data_mapping": {
      "标题": "policy_title",
      "发布时间": "release_date", 
      "发布单位": "release_organization",
      "内容": "policy_content",
      "政策级别": "policy_level",
      "政策解读": "policy_interpretation"
    }
  },
