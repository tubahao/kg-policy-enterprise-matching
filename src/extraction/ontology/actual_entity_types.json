      "所属城市": "string", 
      "所属区县": "string",
      "企业类型": "enum",
      "所属行业": "enum",
      "经营范围": "text",
      "行业大类": "string",
      "参保人员数据": "object"
    },
    "attribute_constraints": {
      "企业名称": {"required": true, "max_length": 100},
      "经营状态": {"required": true, "values": ["存续", "在业", "注销", "吊销", "停业", "开业"]},
      "法定代表人": {"required": false, "max_length": 50},
      "注册资本": {"required": false, "min_value": 0, "type": "float"},
      "成立日期": {"required": false, "format": "YYYY-MM-DD"},
      "所属省份": {"required": false, "max_length": 20},
      "所属城市": {"required": false, "max_length": 20},
      "所属区县": {"required": false, "max_length": 20},
      "企业类型": {"required": false, "values": ["个体工商户", "有限责任公司(自然人投资或控股)", "有限责任公司(自然人独资)", "个人独资企业", "其他有限责任公司"]},
      "所属行业": {"required": true},
      "经营范围": {"required": false, "max_length": 1000},
      "行业大类": {"required": false, "max_length": 100},
      "参保人员数据": {"required": false, "type": "object", "description": "字典格式，年份作为key，参保人数作为value，例如：{'2024年参保人数': 5, '2023年参保人数': 8}"}
    },
    "examples": ["制造企业", "科技服务企业", "文化娱乐企业"],
    "data_mapping": {
      "企业名称": "enterprise_name",
      "经营状态": "business_status",
      "注册资本": "registered_capital",
      "成立日期": "establishment_date",
      "所属行业": "industry_type",
      "企业类型": "enterprise_type",
      "行业大类": "industry_category",
      "参保人员数据": "insurance_data"
    }
